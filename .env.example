# Optional default URL used when no URL is passed on CLI
AMAZON_URL=

# Alert defaults (0 means disabled)
TARGET_PRICE=0
DROP_ALERT_PERCENT=0

# History output
PRICE_HISTORY_FILE=price_history.csv

# Email settings (required only if you want email alerts)
SMTP_ADDRESS=smtp.gmail.com
EMAIL_ADDRESS=your_email@example.com
EMAIL_PASSWORD=your_app_password
